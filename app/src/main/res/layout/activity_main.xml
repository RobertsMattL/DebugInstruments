<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/hudOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="12dp"
        android:layout_marginTop="40dp"
        android:background="#CC000000"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvHudTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="INSTRUMENTS"
            android:textColor="#00FF41"
            android:textSize="11sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="6dp"
            android:background="#4400FF41" />

        <TextView
            android:id="@+id/tvAccelX"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="ACC X:  0.00"
            android:textColor="#00FF41"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvAccelY"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="ACC Y:  0.00"
            android:textColor="#00FF41"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvAccelZ"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="ACC Z:  0.00"
            android:textColor="#00FF41"
            android:textSize="11sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:background="#4400FF41" />

        <TextView
            android:id="@+id/tvLat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="LAT:    0.000000"
            android:textColor="#00FF41"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvLng"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="LNG:    0.000000"
            android:textColor="#00FF41"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvElev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="ELEV:   0.0 m"
            android:textColor="#00FF41"
            android:textSize="11sp" />

    </LinearLayout>

</FrameLayout>
